#!/usr/bin/env sh
# Husky pre-push hook — TRANSFORM SaaS
# Lance les tests pytest marker "regression" avant tout push.
# Protège les patches Sprint Hardening + Phase 3 (Batches 1-6) contre les
# régressions accidentelles. Echec → push bloqué.
#
# Bypass exceptionnel : git push --no-verify (DÉCONSEILLÉ — utiliser uniquement
# si vraiment justifié et avec validation Antoine).

set -e

# Couleurs (compat dash/bash)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RESET='\033[0m'

echo ""
echo "${YELLOW}🛡️  Running regression tests before push...${RESET}"
echo ""

# Cd absolu vers /app/backend (depuis n'importe où dans le repo)
cd "$(git rev-parse --show-toplevel)/backend" || {
    echo "${RED}❌ Impossible d'accéder à /app/backend${RESET}"
    exit 1
}

# Lance UNIQUEMENT les tests marker "regression" (rapide, <2s typiquement)
if python -m pytest -m regression -q --tb=short; then
    echo ""
    echo "${GREEN}✅ Tests régression OK — push autorisé.${RESET}"
    echo ""
    exit 0
else
    echo ""
    echo "${RED}❌ Tests régression échoués. Push BLOQUÉ.${RESET}"
    echo ""
    echo "${YELLOW}Pour debug local :${RESET}"
    echo "    cd /app/backend && python -m pytest -m regression -v"
    echo ""
    echo "${YELLOW}Bypass exceptionnel (déconseillé) :${RESET}"
    echo "    git push --no-verify"
    echo ""
    exit 1
fi
